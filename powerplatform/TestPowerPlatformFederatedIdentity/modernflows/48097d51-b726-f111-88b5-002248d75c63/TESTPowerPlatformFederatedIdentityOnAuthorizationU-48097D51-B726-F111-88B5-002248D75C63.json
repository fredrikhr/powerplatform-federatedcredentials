{
  "properties": {
    "connectionReferences": {
      "shared_commondataserviceforapps": {
        "impersonation": {
          "source": "invoker"
        },
        "runtimeSource": "embedded",
        "connection": {
          "connectionReferenceLogicalName": "test_pwrplatf_pp-fic_dataverse"
        },
        "api": {
          "name": "shared_commondataserviceforapps"
        }
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "$connections": {
          "defaultValue": {},
          "type": "Object"
        },
        "$authentication": {
          "defaultValue": {},
          "type": "SecureObject"
        }
      },
      "triggers": {
        "When_a_User_Authorization_URL_is_generated": {
          "metadata": {
            "operationMetadataId": "02e7e0ed-ab6f-4d1b-9ae7-d6868ae1d9eb"
          },
          "type": "OpenApiConnectionWebhook",
          "inputs": {
            "host": {
              "connectionName": "shared_commondataserviceforapps",
              "operationId": "BusinessEventsTrigger",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
            },
            "parameters": {
              "catalog": "allcatalog",
              "category": "allcategory",
              "subscriptionRequest/entityname": "none",
              "subscriptionRequest/sdkmessagename": "pwrplatf_GenerateAuthorizationUrl"
            },
            "authentication": "@parameters('$authentication')"
          }
        }
      },
      "actions": {
        "Send_User_Authorization_Notification": {
          "runAfter": {
            "Notification_Action": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "37de09e7-81b1-40fb-9f16-e7c3db1c5827"
          },
          "type": "OpenApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_commondataserviceforapps",
              "operationId": "PerformUnboundAction",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
            },
            "parameters": {
              "actionName": "SendAppNotification",
              "item/Recipient": "/systemusers(@{triggerBody()['RunAsSystemUserId']})",
              "item/Title": "TEST | Complete Sign-In",
              "item/Body": "This is a test for completing a sign-in for use in a background Power Platform operation",
              "item/Expiry": 1800,
              "item/IconType": 100000000,
              "item/ToastType": 200000000,
              "item/Priority": 200000000,
              "item/Actions": "@outputs('Notification_Action')"
            },
            "authentication": "@parameters('$authentication')"
          }
        },
        "Notification_Action": {
          "runAfter": {},
          "metadata": {
            "operationMetadataId": "c41e3acb-2d10-45a3-a181-6e6dc68f2d6f"
          },
          "type": "Compose",
          "inputs": {
            "@@odata.type": "Microsoft.Dynamics.CRM.expando",
            "actions@odata.type": "#Collection(Microsoft.Dynamics.CRM.expando)",
            "actions": [
              {
                "title": "Sign in",
                "data": {
                  "@@odata.type": "#Microsoft.Dynamics.CRM.expando",
                  "type": "url",
                  "url": "@triggerOutputs()?['body/OutputParameters/AuthorizationRequestUrl']",
                  "navigationTarget": "dialog"
                }
              }
            ]
          }
        }
      }
    },
    "templateName": null
  },
  "schemaVersion": "1.0.0.0"
}